<Window x:Class="BetterDiskCleanup.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BetterDiskCleanup.App.ViewModels"
        xmlns:controls="clr-namespace:BetterDiskCleanup.App.Controls"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Title="Better Disk Cleanup"
        Height="700" Width="980"
        MinHeight="520" MinWidth="780"
        WindowStartupLocation="CenterScreen">

    <Border Background="{StaticResource BgDeep}" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="24"
                              Opacity="0.4" Color="Black" />
        </Border.Effect>

        <DockPanel LastChildFill="True">

            <!-- ===== TITLE BAR ===== -->
            <Grid DockPanel.Dock="Top" Height="44"
                  Background="{StaticResource BgBase}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="Better Disk Cleanup"
                           VerticalAlignment="Center" Margin="20,0,0,0"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="13" FontWeight="Medium" />
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,6,0">
                    <Button Content="─" Click="Minimize_Click" Width="44" Height="34"
                            Style="{StaticResource SecondaryButton}" Padding="0"
                            FontSize="11" BorderThickness="0" />
                    <Button x:Name="MaximizeBtn" Content="□" Click="Maximize_Click"
                            Width="44" Height="34"
                            Style="{StaticResource SecondaryButton}" Padding="0"
                            FontSize="14" BorderThickness="0" />
                    <Button Content="✕" Click="Close_Click" Width="44" Height="34"
                            Style="{StaticResource DangerButton}" Padding="0"
                            FontSize="13" />
                </StackPanel>
            </Grid>

            <!-- ===== SIDEBAR ===== -->
            <Border DockPanel.Dock="Left" Width="224"
                    Background="{StaticResource BgBase}"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="0,0,1,0">
                <DockPanel>

                    <!-- Brand -->
                    <Border DockPanel.Dock="Top" Height="56" Padding="20,0,12,0">
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <Ellipse Width="10" Height="10"
                                     Fill="{StaticResource AccentGradient}" Margin="0,0,10,0" />
                            <TextBlock Text="Disk Cleanup" FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}" />
                        </StackPanel>
                    </Border>

                    <!-- Version + Log Toggle -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="12,0,12,14">
                        <Button Content="Toggle Log"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding ToggleLogCommand}"
                                Padding="8,5" FontSize="10" Margin="0,0,0,6" />
                        <TextBlock Text="v1.0 · Fase 4"
                                   Style="{StaticResource SubText}" />
                    </StackPanel>

                    <!-- Nav Buttons -->
                    <StackPanel Margin="0,8,0,0">
                        <RadioButton Style="{StaticResource NavButton}"
                                     IsChecked="{Binding SelectedIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=0, Mode=TwoWay}"
                                     Command="{Binding SelectPageCommand}"
                                     CommandParameter="0">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M 3,13 L 3,21 L 11,21 L 11,13 Z M 13,3 L 13,11 L 21,11 L 21,3 Z M 13,13 L 13,21 L 21,21 L 21,13 Z M 3,3 L 3,11 L 11,11 L 11,3 Z"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                      StrokeThickness="1.5" Width="18" Height="18" Stretch="Uniform" Margin="0,0,10,0" />
                                <TextBlock Text="Dashboard" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavButton}"
                                     IsChecked="{Binding SelectedIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=1, Mode=TwoWay}"
                                     Command="{Binding SelectPageCommand}"
                                     CommandParameter="1">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M 4,2 L 12,2 L 16,6 L 16,18 L 4,18 Z M 12,2 L 12,6 L 16,6"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                      StrokeThickness="1.5" Width="18" Height="18"
                                      Stretch="Uniform" Margin="0,0,10,0" />
                                <TextBlock Text="Temp Cleanup" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavButton}"
                                     IsChecked="{Binding SelectedIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=2, Mode=TwoWay}"
                                     Command="{Binding SelectPageCommand}"
                                     CommandParameter="2">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M 10,1 L 2,5 L 2,11 C 2,16 10,19 10,19 C 10,19 18,16 18,11 L 18,5 Z"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                      StrokeThickness="1.5" Width="18" Height="18"
                                      Stretch="Uniform" Margin="0,0,10,0" />
                                <TextBlock Text="Browser Cleanup" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavButton}"
                                     IsChecked="{Binding SelectedIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=3, Mode=TwoWay}"
                                     Command="{Binding SelectPageCommand}"
                                     CommandParameter="3">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M 13,3 A 7,7 0 1,0 17,10 M 17,5 L 17,10 L 12,10"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                      StrokeThickness="1.5" Width="18" Height="18"
                                      Stretch="Uniform" Margin="0,0,10,0" />
                                <TextBlock Text="Recovery History" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavButton}"
                                     IsChecked="{Binding SelectedIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=4, Mode=TwoWay}"
                                     Command="{Binding SelectPageCommand}"
                                     CommandParameter="4">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M 3,3 L 17,3 L 17,17 L 3,17 Z M 7,7 L 13,7 M 7,10 L 13,10 M 7,13 L 11,13"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                      StrokeThickness="1.5" Width="18" Height="18"
                                      Stretch="Uniform" Margin="0,0,10,0" />
                                <TextBlock Text="Large Files" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavButton}"
                                     IsChecked="{Binding SelectedIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=5, Mode=TwoWay}"
                                     Command="{Binding SelectPageCommand}"
                                     CommandParameter="5">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M 4,4 L 8,4 L 8,8 L 4,8 Z M 12,4 L 16,4 L 16,8 L 12,8 Z M 4,12 L 8,12 L 8,16 L 4,16 Z M 12,12 L 16,12 L 16,16 L 12,16 Z"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                      StrokeThickness="1.5" Width="18" Height="18"
                                      Stretch="Uniform" Margin="0,0,10,0" />
                                <TextBlock Text="Duplicates" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavButton}"
                                     IsChecked="{Binding SelectedIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=6, Mode=TwoWay}"
                                     Command="{Binding SelectPageCommand}"
                                     CommandParameter="6">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M 3,3 L 17,3 L 17,17 L 3,17 Z M 7,7 L 13,7 M 7,10 L 13,10 M 10,13 L 10,17"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                      StrokeThickness="1.5" Width="18" Height="18"
                                      Stretch="Uniform" Margin="0,0,10,0" />
                                <TextBlock Text="Startup Manager" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavButton}"
                                     IsChecked="{Binding SelectedIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=9, Mode=TwoWay}"
                                     Command="{Binding SelectPageCommand}"
                                     CommandParameter="9">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M 3,3 L 17,3 L 17,17 L 3,17 Z M 3,10 L 17,10 M 10,3 L 10,10 M 10,10 L 10,17 M 3,10 L 10,10"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                      StrokeThickness="1.5" Width="18" Height="18"
                                      Stretch="Uniform" Margin="0,0,10,0" />
                                <TextBlock Text="Storage Analyzer" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource NavButton}"
                                     IsChecked="{Binding SelectedIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=7, Mode=TwoWay}"
                                     Command="{Binding SelectPageCommand}"
                                     CommandParameter="7">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M 14,2 L 6,2 C 4.89,2 4,2.9 4,4 L 4,20 C 4,21.1 4.89,22 6,22 L 18,22 C 19.1,22 20,21.1 20,20 L 20,8 L 14,2 Z"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                      StrokeThickness="1.5" Width="18" Height="18" Stretch="Uniform" Margin="0,0,10,0" />
                                <TextBlock Text="Reports" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavButton}"
                                     IsChecked="{Binding SelectedIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=8, Mode=TwoWay}"
                                     Command="{Binding SelectPageCommand}"
                                     CommandParameter="8">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M 19.43,12.98 C 19.47,12.66 19.5,12.34 19.5,12 C 19.5,11.66 19.47,11.34 19.43,11.02 L 21.54,9.37 C 21.73,9.22 21.78,8.95 21.66,8.73 L 19.66,5.27 C 19.54,5.05 19.27,4.96 19.05,5.05 L 16.56,6.05 C 16.04,5.65 15.48,5.32 14.87,5.07 L 14.49,2.42 C 14.46,2.18 14.25,2 14,2 L 10,2 C 9.75,2 9.54,2.18 9.51,2.42 L 9.13,5.07 C 8.52,5.32 7.96,5.66 7.44,6.05 L 4.95,5.05 C 4.73,4.96 4.46,5.05 4.34,5.27 L 2.34,8.73 C 2.21,8.95 2.27,9.22 2.46,9.37 L 4.57,11.02 C 4.53,11.34 4.5,11.67 4.5,12 C 4.5,12.33 4.53,12.66 4.57,12.98 L 2.46,14.63 C 2.27,14.78 2.21,15.05 2.34,15.27 L 4.34,18.73 C 4.46,18.95 4.73,19.03 4.95,18.95 L 7.44,17.95 C 7.96,18.35 8.52,18.68 9.13,18.93 L 9.51,21.58 C 9.54,21.82 9.75,22 10,22 L 14,22 C 14.25,22 14.46,21.82 14.49,21.58 L 14.87,18.93 C 15.48,18.68 16.04,18.34 16.56,17.95 L 19.05,18.95 C 19.27,19.03 19.54,18.95 19.66,18.73 L 21.66,15.27 C 21.78,15.05 21.73,14.78 21.54,14.63 L 19.43,12.98 Z M 12,15.5 C 10.07,15.5 8.5,13.93 8.5,12 C 8.5,10.07 10.07,8.5 12,8.5 C 13.93,8.5 15.5,10.07 15.5,12 C 15.5,13.93 13.93,15.5 12,15.5 Z"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                      StrokeThickness="1.5" Width="18" Height="18" Stretch="Uniform" Margin="0,0,10,0" />
                                <TextBlock Text="Settings" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ===== MAIN CONTENT AREA (pages + log panel) ===== -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>


            <!-- ===== PAGE: DASHBOARD ===== -->
            <Grid Visibility="{Binding IsDashboardPage, Converter={StaticResource BoolToVis}}" Style="{StaticResource PageGridStyle}">
                <Grid DataContext="{Binding DataContext.DashboardViewModel, RelativeSource={RelativeSource AncestorType=Window}}" Margin="28,24,28,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,22">
                        <TextBlock Text="Dashboard" Style="{StaticResource PageHeader}" />
                        <TextBlock Text="System overview and health status" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0" FontSize="13" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,18">
                        <Button Content="Refresh Stats" Style="{StaticResource PrimaryButton}" Command="{Binding RefreshCommand}" />
                    </StackPanel>

                        <!-- Stats View (When Scanned) -->
                        <Grid Grid.Row="2" Visibility="{Binding HasScannedAny, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            
                            <Border Grid.Row="0" Grid.Column="0" Margin="0,0,10,10" Style="{StaticResource CardBorder}" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Health Score" Foreground="{StaticResource TextMuted}" FontSize="14" />
                                    <TextBlock Text="{Binding HealthScoreDisplay}" Foreground="{StaticResource Accent}" FontSize="48" FontWeight="Bold" Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                            
                            <Border Grid.Row="0" Grid.Column="1" Margin="10,0,0,10" Style="{StaticResource CardBorder}" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Total Recoverable Space" Foreground="{StaticResource TextMuted}" FontSize="14" />
                                    <TextBlock Text="{Binding TotalRecoverableSpaceDisplay}" Foreground="{StaticResource TextPrimary}" FontSize="32" FontWeight="Bold" Margin="0,8,0,0" />
                                    <TextBlock Text="{Binding JunkFilesFound, StringFormat='{}from {0} junk files'}" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            
                            <Border Grid.Row="1" Grid.Column="0" Margin="0,10,10,0" Style="{StaticResource CardBorder}" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Free Space Remaining" Foreground="{StaticResource TextMuted}" FontSize="14" />
                                    <TextBlock Text="{Binding FreeSpaceDisplay}" Foreground="{StaticResource TextPrimary}" FontSize="32" FontWeight="Bold" Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                            
                            <Border Grid.Row="1" Grid.Column="1" Margin="10,10,0,0" Style="{StaticResource CardBorder}" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Startup Impact" Foreground="{StaticResource TextMuted}" FontSize="14" />
                                    <TextBlock Text="{Binding HighImpactStartups, StringFormat='{}{0} High Impact'}" Foreground="{StaticResource Danger}" FontSize="32" FontWeight="Bold" Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- CTA View (When NOT Scanned) -->
                        <Border Grid.Row="2" Visibility="{Binding HasScannedAny, Converter={StaticResource InvertBool}}" 
                                Style="{StaticResource CardBorder}" Padding="32" VerticalAlignment="Center">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="No Scan Data Available" Foreground="{StaticResource TextPrimary}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" />
                                <TextBlock Text="You haven't performed any scans yet. Navigate to any module to scan your PC and generate your health dashboard." Foreground="{StaticResource TextSecondary}" FontSize="14" TextWrapping="Wrap" TextAlignment="Center" Margin="0,12,0,24" MaxWidth="400" />
                                <Button Content="Start scanning Temporary Files" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Center" Command="{Binding DataContext.SelectPageCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="1" />
                            </StackPanel>
                        </Border>
                </Grid>
            </Grid>
            <!-- ===== PAGE: TEMP CLEANUP ===== -->
            <Grid Visibility="{Binding IsTempPage, Converter={StaticResource BoolToVis}}" Style="{StaticResource PageGridStyle}">
                <Grid DataContext="{Binding DataContext.CleanupViewModel, RelativeSource={RelativeSource AncestorType=Window}}"
                      Margin="28,24,28,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,22">
                        <TextBlock Text="Temporary File Cleanup"
                                   Style="{StaticResource PageHeader}" />
                        <TextBlock Text="Scan and remove Windows and user temp files safely"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,4,0,0" FontSize="13" />
                    </StackPanel>

                    <!-- Action Bar -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,18">
                        <Button Content="Scan Temp Files"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding ScanCommand}" Margin="0,0,8,0" />
                        <Button Content="Preview Cleanup"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding PreviewCommand}" Margin="0,0,8,0" />
                        <Button Content="Clean Now"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding CleanCommand}" Margin="0,0,8,0" />
                        <Button Content="Cancel"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding CancelScanCommand}" Opacity="0.7" />
                    </StackPanel>

                    <!-- Status -->
                    <Border Grid.Row="2" Margin="0,0,0,14"
                            Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding ProgressText}"
                                   Foreground="{StaticResource Accent}" FontSize="12" />
                    </Border>

                    <!-- Result Cards -->
                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="SCAN RESULTS"
                                               Style="{StaticResource SectionHeader}" Margin="0,0,0,8" />
                                    <TextBlock Text="{Binding ScanSummary}"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource TextSecondary}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="PREVIEW"
                                               Style="{StaticResource SectionHeader}" Margin="0,0,0,8" />
                                    <TextBlock Text="{Binding PreviewSummary}"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource TextSecondary}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="CLEANUP REPORT"
                                               Style="{StaticResource SectionHeader}" Margin="0,0,0,8" />
                                    <TextBlock Text="{Binding ReportSummary}"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource TextSecondary}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- ===== PAGE: BROWSER CLEANUP ===== -->
            <Grid Visibility="{Binding IsBrowserPage, Converter={StaticResource BoolToVis}}" Style="{StaticResource PageGridStyle}">
                <Grid DataContext="{Binding DataContext.BrowserCleanupViewModel, RelativeSource={RelativeSource AncestorType=Window}}"
                      Margin="28,24,28,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,22">
                        <TextBlock Text="Browser Data Cleanup"
                                   Style="{StaticResource PageHeader}" />
                        <TextBlock Text="Detect browsers and clean cache, cookies, and more"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,4,0,0" FontSize="13" />
                    </StackPanel>

                    <!-- Action Bar -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,14">
                        <Button Content="Detect &amp; Scan"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding DetectCommand}" Margin="0,0,8,0" />
                        <Button Content="Preview Cleanup"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding PreviewCommand}" Margin="0,0,8,0" />
                        <Button Content="Clean Selected"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding CleanCommand}" Margin="0,0,8,0" />
                        <Button Content="Cancel"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding CancelScanCommand}" Opacity="0.7" />
                    </StackPanel>

                    <!-- Warning -->
                    <Border Grid.Row="2"
                            Background="#2A1215" BorderBrush="#5C2020"
                            BorderThickness="1" CornerRadius="8"
                            Padding="14,10" Margin="0,0,0,10"
                            Visibility="{Binding HasBrowserWarning, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding BrowserWarning}"
                                   Foreground="{StaticResource Danger}"
                                   TextWrapping="Wrap" FontSize="12" />
                    </Border>

                    <!-- Summaries -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,10">
                        <TextBlock Text="{Binding ScanSummary}"
                                   Foreground="{StaticResource TextSecondary}" FontSize="12" />
                        <TextBlock Text="{Binding PreviewSummary}"
                                   Foreground="{StaticResource TextSecondary}" FontSize="12" />
                        <TextBlock Text="{Binding ReportSummary}"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="12" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding ProgressText}"
                                   Foreground="{StaticResource Accent}" FontSize="12" />
                    </StackPanel>

                    <!-- Browser Groups -->
                    <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding BrowserGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                                        <StackPanel>
                                            <!-- Browser Name -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                <Ellipse Width="8" Height="8"
                                                         Fill="{StaticResource Accent}"
                                                         Margin="0,0,10,0" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding BrowserName}"
                                                           FontSize="15" FontWeight="Bold"
                                                           Foreground="{StaticResource TextPrimary}" />
                                            </StackPanel>

                                            <!-- Profiles -->
                                            <ItemsControl ItemsSource="{Binding Profiles}" Margin="18,0,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0,0,0,10">
                                                            <TextBlock Text="{Binding ProfileName}"
                                                                       FontWeight="SemiBold" FontSize="13"
                                                                       Foreground="{StaticResource TextSecondary}"
                                                                       Margin="0,0,0,6" />
                                                            <!-- Data Entries -->
                                                            <ItemsControl ItemsSource="{Binding DataEntries}"
                                                                          Margin="14,0,0,0">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Padding="6,5" Margin="0,1"
                                                                                CornerRadius="5"
                                                                                Background="Transparent">
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="Auto" />
                                                                                    <ColumnDefinition Width="*" />
                                                                                    <ColumnDefinition Width="Auto" />
                                                                                </Grid.ColumnDefinitions>
                                                                                <CheckBox Grid.Column="0"
                                                                                          IsChecked="{Binding IsSelected}"
                                                                                          VerticalAlignment="Center"
                                                                                          Margin="0,0,8,0" />
                                                                                <TextBlock Grid.Column="1"
                                                                                           Text="{Binding DisplayText}"
                                                                                           VerticalAlignment="Center"
                                                                                           Foreground="{StaticResource TextPrimary}"
                                                                                           FontSize="13" />
                                                                                <Border Grid.Column="2"
                                                                                        CornerRadius="4" Padding="7,3"
                                                                                        VerticalAlignment="Center"
                                                                                        Margin="8,0,0,0">
                                                                                    <Border.Style>
                                                                                        <Style TargetType="Border">
                                                                                            <Setter Property="Background" Value="#0D2A20" />
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding IsSensitiveData}" Value="True">
                                                                                                    <Setter Property="Background" Value="#2A1A0A" />
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </Border.Style>
                                                                                    <TextBlock Text="{Binding RiskLabel}"
                                                                                               FontSize="11" FontWeight="Medium">
                                                                                        <TextBlock.Style>
                                                                                            <Style TargetType="TextBlock">
                                                                                                <Setter Property="Foreground" Value="{StaticResource Success}" />
                                                                                                <Style.Triggers>
                                                                                                    <DataTrigger Binding="{Binding IsSensitiveData}" Value="True">
                                                                                                        <Setter Property="Foreground" Value="{StaticResource Warning}" />
                                                                                                    </DataTrigger>
                                                                                                </Style.Triggers>
                                                                                            </Style>
                                                                                        </TextBlock.Style>
                                                                                    </TextBlock>
                                                                                </Border>
                                                                            </Grid>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- ===== PAGE: RECOVERY HISTORY ===== -->
            <Grid Visibility="{Binding IsRecoveryPage, Converter={StaticResource BoolToVis}}" Style="{StaticResource PageGridStyle}">
                <Grid DataContext="{Binding DataContext.RecoveryHistoryViewModel, RelativeSource={RelativeSource AncestorType=Window}}"
                      Margin="28,24,28,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,22">
                        <TextBlock Text="Recovery History"
                                   Style="{StaticResource PageHeader}" />
                        <TextBlock Text="Restore or purge previously cleaned files"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,4,0,0" FontSize="13" />
                    </StackPanel>

                    <!-- Action Bar -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,14">
                        <Button Content="Refresh"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding RefreshCommand}" Margin="0,0,8,0" />
                        <Button Content="Purge Expired"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding PurgeExpiredCommand}" />
                    </StackPanel>

                    <!-- Status -->
                    <TextBlock Grid.Row="2"
                               Text="{Binding StatusMessage}"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="12" Margin="0,0,0,12" />

                    <!-- Sessions -->
                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Sessions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding SummaryText}"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextSecondary}"
                                                           FontSize="13" VerticalAlignment="Center" />
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <Button Content="Details"
                                                            Style="{StaticResource SecondaryButton}"
                                                            Command="{Binding ToggleExpandedCommand}"
                                                            Padding="12,6" FontSize="12" Margin="0,0,6,0" />
                                                    <Button Content="Restore"
                                                            Style="{StaticResource PrimaryButton}"
                                                            Command="{Binding RestoreSessionCommand}"
                                                            Padding="12,6" FontSize="12" Margin="0,0,6,0" />
                                                    <Button Content="Purge"
                                                            Style="{StaticResource DangerButton}"
                                                            Command="{Binding PurgeSessionCommand}"
                                                            Padding="12,6" FontSize="12" />
                                                </StackPanel>
                                            </Grid>

                                            <!-- Expanded Items -->
                                            <ItemsControl ItemsSource="{Binding Items}"
                                                          Margin="0,12,0,0"
                                                          Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="10,8" Margin="0,2"
                                                                CornerRadius="6"
                                                                Background="{StaticResource BgSurface}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0"
                                                                           Text="{Binding DisplayText}"
                                                                           TextWrapping="Wrap"
                                                                           Foreground="{StaticResource TextSecondary}"
                                                                           FontSize="12" VerticalAlignment="Center" />
                                                                <Button Grid.Column="1"
                                                                        Content="Restore Item"
                                                                        Style="{StaticResource SecondaryButton}"
                                                                        Command="{Binding RestoreItemCommand}"
                                                                        Padding="10,5" FontSize="11" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- ===== PAGE: LARGE FILES ===== -->
            <Grid Visibility="{Binding IsLargeFilesPage, Converter={StaticResource BoolToVis}}" Style="{StaticResource PageGridStyle}">
                <Grid DataContext="{Binding DataContext.LargeFileFinderViewModel, RelativeSource={RelativeSource AncestorType=Window}}"
                      Margin="28,24,28,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="Large File Finder"
                                   Style="{StaticResource PageHeader}" />
                        <TextBlock Text="Find and manage large files taking up disk space"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,3,0,0" FontSize="12" />
                    </StackPanel>

                    <!-- Scan Controls -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <ComboBox ItemsSource="{Binding AvailableDrives}"
                                  SelectedItem="{Binding SelectedDrive}"
                                  Width="130" Margin="0,0,6,0" />
                        <ComboBox ItemsSource="{Binding ThresholdOptions}"
                                  SelectedItem="{Binding SelectedThreshold}"
                                  Width="90" Margin="0,0,6,0" />
                        <Button Content="Scan"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding ScanCommand}" Margin="0,0,6,0" />
                        <Button Content="Cancel"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding CancelScanCommand}" Opacity="0.7" />
                    </StackPanel>

                    <!-- Search + Delete -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Width="220" Margin="0,0,6,0" />
                        <Button Content="Delete Selected"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding DeleteCommand}" Margin="0,0,6,0" />
                    </StackPanel>

                    <!-- Status / Summary -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,8">
                        <TextBlock Text="{Binding SummaryText}"
                                   Foreground="{StaticResource TextSecondary}" FontSize="11" />
                        <TextBlock Text="{Binding ReportSummary}"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="11" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding ProgressText}"
                                   Foreground="{StaticResource Accent}" FontSize="11" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11" Margin="0,2,0,0" />
                    </StackPanel>

                    <!-- Results Table -->
                    <ListView Grid.Row="4"
                              ItemsSource="{Binding Results}"
                              Background="Transparent"
                              BorderThickness="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="36">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected}" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="File Name" Width="220"
                                                DisplayMemberBinding="{Binding Entry.FileName}" />
                                <GridViewColumn Header="Size" Width="90"
                                                DisplayMemberBinding="{Binding SizeDisplay}" />
                                <GridViewColumn Header="Type" Width="80"
                                                DisplayMemberBinding="{Binding CategoryDisplay}" />
                                <GridViewColumn Header="Location" Width="280"
                                                DisplayMemberBinding="{Binding LocationDisplay}" />
                                <GridViewColumn Header="Modified" Width="130"
                                                DisplayMemberBinding="{Binding DateDisplay}" />
                            </GridView>
                        </ListView.View>
                        <ListView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Open File"
                                          Command="{Binding DataContext.OpenFileCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                          CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <MenuItem Header="Open Folder"
                                          Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                          CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            </ContextMenu>
                        </ListView.ContextMenu>
                    </ListView>
                </Grid>
            </Grid>

            <!-- ===== PAGE: DUPLICATE FINDER ===== -->
            <Grid Visibility="{Binding IsDuplicatesPage, Converter={StaticResource BoolToVis}}" Style="{StaticResource PageGridStyle}">
                <Grid DataContext="{Binding DataContext.DuplicateFinderViewModel, RelativeSource={RelativeSource AncestorType=Window}}"
                      Margin="28,24,28,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="Duplicate File Finder"
                                   Style="{StaticResource PageHeader}" />
                        <TextBlock Text="Find and remove duplicate files to reclaim disk space"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,3,0,0" FontSize="12" />
                    </StackPanel>

                    <!-- Scan Controls -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBox Text="{Binding FolderPath, UpdateSourceTrigger=PropertyChanged}"
                                 Width="320" Margin="0,0,6,0" />
                        <Button Content="Scan"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding ScanCommand}" Margin="0,0,6,0" />
                        <Button Content="Cancel"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding CancelScanCommand}" Opacity="0.7" />
                    </StackPanel>

                    <!-- Strategy + Delete -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Strategy:" Foreground="{StaticResource TextMuted}"
                                   FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <ComboBox ItemsSource="{Binding StrategyOptions}"
                                  SelectedItem="{Binding SelectedStrategy}"
                                  Width="140" Margin="0,0,12,0" />
                        <Button Content="Delete Selected"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding DeleteCommand}" />
                    </StackPanel>

                    <!-- Status / Summary -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,8">
                        <TextBlock Text="{Binding SummaryText}"
                                   Foreground="{StaticResource TextSecondary}" FontSize="11" />
                        <TextBlock Text="{Binding ReportSummary}"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="11" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding ProgressText}"
                                   Foreground="{StaticResource Accent}" FontSize="11" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11" Margin="0,2,0,0" />
                    </StackPanel>

                    <!-- Expand/Collapse hint -->
                    <TextBlock Grid.Row="4"
                               Text="Click a group to expand and review individual files."
                               Foreground="{StaticResource TextMuted}"
                               FontSize="11" Margin="0,0,0,6" />

                    <!-- Duplicate Groups -->
                    <ScrollViewer Grid.Row="5" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Groups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                                        <StackPanel>
                                            <!-- Group Header (clickable to expand) -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Foreground="{StaticResource Accent}"
                                                           FontSize="12" VerticalAlignment="Center"
                                                           Margin="0,0,8,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="▸" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                    <Setter Property="Text" Value="▾" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding GroupHeader}"
                                                               Foreground="{StaticResource TextPrimary}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Cursor="Hand"
                                                               MouseLeftButtonDown="ToggleGroupExpand" />
                                                    <TextBlock Text="{Binding HashDisplay}"
                                                               Foreground="{StaticResource TextMuted}"
                                                               FontSize="10" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Grid>

                                            <!-- Expanded Members -->
                                            <ItemsControl ItemsSource="{Binding Members}"
                                                          Margin="18,8,0,0"
                                                          Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="6,5" Margin="0,1"
                                                                CornerRadius="5"
                                                                Background="Transparent">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <CheckBox Grid.Column="0"
                                                                          IsChecked="{Binding IsSelected}"
                                                                          VerticalAlignment="Center"
                                                                          Margin="0,0,8,0" />
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding Entry.FileName}"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{StaticResource TextPrimary}"
                                                                           FontSize="12" />
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{Binding SizeDisplay}"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{StaticResource TextMuted}"
                                                                           FontSize="11" Margin="8,0,8,0" />
                                                                <TextBlock Grid.Column="3"
                                                                           Text="{Binding LocationDisplay}"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{StaticResource TextMuted}"
                                                                           FontSize="10" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- ===== PAGE: STARTUP MANAGER ===== -->
            <Grid Visibility="{Binding IsStartupPage, Converter={StaticResource BoolToVis}}" Style="{StaticResource PageGridStyle}">
                <Grid DataContext="{Binding DataContext.StartupManagerViewModel, RelativeSource={RelativeSource AncestorType=Window}}"
                      Margin="28,24,28,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="Startup Manager"
                                   Style="{StaticResource PageHeader}" />
                        <TextBlock Text="Manage programs that start automatically with Windows"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,3,0,0" FontSize="12" />
                    </StackPanel>

                    <!-- Action Bar -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Scan Startup Entries"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding ScanCommand}" Margin="0,0,8,0" />
                        <Button Content="Undo Last Change"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding UndoLastChangeCommand}" Margin="0,0,8,0" />
                    </StackPanel>

                    <!-- Status / Summary -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,8">
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource TextSecondary}" FontSize="11" />
                        <TextBlock Text="{Binding ProgressText}"
                                   Foreground="{StaticResource Accent}" FontSize="11" />
                    </StackPanel>

                    <!-- Startup Entries Table -->
                    <ListView Grid.Row="3"
                              ItemsSource="{Binding Entries}"
                              Background="Transparent"
                              BorderThickness="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name" Width="180"
                                                DisplayMemberBinding="{Binding Name}" />
                                <GridViewColumn Header="Publisher" Width="150"
                                                DisplayMemberBinding="{Binding Publisher}" />
                                <GridViewColumn Header="Path" Width="240"
                                                DisplayMemberBinding="{Binding FilePath}" />
                                <GridViewColumn Header="Status" Width="80"
                                                DisplayMemberBinding="{Binding StatusDisplay}" />
                                <GridViewColumn Header="Impact" Width="70"
                                                DisplayMemberBinding="{Binding ImpactDisplay}" />
                                <GridViewColumn Header="Source" Width="100"
                                                DisplayMemberBinding="{Binding SourceDisplay}" />
                                <GridViewColumn Width="120">
                                    <GridViewColumn.Header>
                                        <GridViewColumnHeader Content="Actions" HorizontalContentAlignment="Center" />
                                    </GridViewColumn.Header>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="Toggle"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Command="{Binding DataContext.ToggleCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                        CommandParameter="{Binding}"
                                                        Padding="8,3" FontSize="10" Margin="0,0,4,0"
                                                        IsEnabled="{Binding IsProtected, Converter={StaticResource InvertBool}}" />
                                                <Button Content="Remove"
                                                        Style="{StaticResource DangerButton}"
                                                        Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                        CommandParameter="{Binding}"
                                                        Padding="8,3" FontSize="10"
                                                        IsEnabled="{Binding IsProtected, Converter={StaticResource InvertBool}}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Grid>

            <!-- ===== PAGE: STORAGE ANALYZER ===== -->
            <Grid Visibility="{Binding IsStorageAnalyzerPage, Converter={StaticResource BoolToVis}}" Style="{StaticResource PageGridStyle}">
                <Grid DataContext="{Binding DataContext.StorageAnalyzerViewModel, RelativeSource={RelativeSource AncestorType=Window}}"
                      Margin="20,18,20,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="220" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,12">
                        <TextBlock Text="Storage Analyzer"
                                   Style="{StaticResource PageHeader}" />
                        <TextBlock Text="Visualize disk usage with interactive treemap"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,3,0,0" FontSize="12" />
                    </StackPanel>

                    <!-- Scan Controls -->
                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,8">
                        <ComboBox ItemsSource="{Binding AvailableDrives}"
                                  SelectedItem="{Binding SelectedDrive}"
                                  Width="110" Margin="0,0,6,0" />
                        <Button Content="Analyze"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding ScanCommand}" Margin="0,0,6,0" />
                        <Button Content="Cancel"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding CancelScanCommand}" Opacity="0.7" />
                    </StackPanel>

                    <!-- Breadcrumb + Status -->
                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,0,0,8">
                        <!-- Breadcrumb -->
                        <ItemsControl ItemsSource="{Binding BreadcrumbPath}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="{Binding Name}"
                                                Style="{StaticResource SecondaryButton}"
                                                Command="{Binding DataContext.BreadcrumbNavigateCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Padding="6,2" FontSize="11" Margin="0,0,2,0" />
                                        <TextBlock Text=">" Foreground="{StaticResource TextMuted}"
                                                   VerticalAlignment="Center" Margin="2,0,4,0" FontSize="11" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{Binding ProgressText}"
                                   Foreground="{StaticResource Accent}" FontSize="11" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11" Margin="0,2,0,0" />
                    </StackPanel>

                    <!-- Treemap (main area) -->
                    <Border Grid.Row="3" Grid.Column="0"
                            Background="{StaticResource BgSurface}"
                            CornerRadius="8" Margin="0,0,10,0"
                            BorderBrush="{StaticResource Border}" BorderThickness="1">
                        <controls:TreemapControl ItemsSource="{Binding TreemapRects}" ItemClicked="TreemapItemClicked">
                            <controls:TreemapControl.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Open Folder"
                                              Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=controls:TreemapControl}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                </ContextMenu>
                            </controls:TreemapControl.ContextMenu>
                        </controls:TreemapControl>
                    </Border>

                    <!-- Sidebar: Pie Chart + Tree View -->
                    <Grid Grid.Row="3" Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Pie Chart -->
                        <Border Grid.Row="0"
                                Background="{StaticResource BgSurface}"
                                CornerRadius="8" Padding="8"
                                Margin="0,0,0,8"
                                BorderBrush="{StaticResource Border}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="FILE TYPES"
                                           Style="{StaticResource SectionHeader}" Margin="0,0,0,4" />
                                <controls:PieChartControl Height="180"
                                                          Segments="{Binding PieSegments}" />
                            </StackPanel>
                        </Border>

                        <!-- Tree View -->
                        <Border Grid.Row="1"
                                Background="{StaticResource BgSurface}"
                                CornerRadius="8" Padding="8"
                                BorderBrush="{StaticResource Border}" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="FOLDERS"
                                           Style="{StaticResource SectionHeader}" Margin="0,0,0,4" />
                                <TreeView Grid.Row="1"
                                          ItemsSource="{Binding TreeItems}"
                                          Background="Transparent" BorderThickness="0"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <TreeView.ItemContainerStyle>
                                        <Style TargetType="TreeViewItem">
                                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                                            <Setter Property="FontSize" Value="11" />
                                            <Setter Property="Padding" Value="2" />
                                        </Style>
                                    </TreeView.ItemContainerStyle>
                                    <TreeView.ItemTemplate>
                                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding SizeDisplay}"
                                                           Foreground="{StaticResource TextMuted}"
                                                           FontSize="10" Margin="6,0,0,0"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </HierarchicalDataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>


            <!-- ===== PAGE: REPORTS ===== -->
            <Grid Visibility="{Binding IsReportsPage, Converter={StaticResource BoolToVis}}" Style="{StaticResource PageGridStyle}">
                <Grid DataContext="{Binding DataContext.ReportsViewModel, RelativeSource={RelativeSource AncestorType=Window}}" Margin="28,24,28,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,22">
                        <TextBlock Text="Reports" Style="{StaticResource PageHeader}" />
                        <TextBlock Text="Export cleanup history and system logs" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0" FontSize="13" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,18">
                        <Button Content="Export Logs (TXT)" Style="{StaticResource PrimaryButton}" Command="{Binding ExportLogsTxtCommand}" Margin="0,0,8,0"/>
                        <Button Content="Export Logs (JSON)" Style="{StaticResource SecondaryButton}" Command="{Binding ExportLogsJsonCommand}" />
                    </StackPanel>
                    
                    <!-- Recovery History goes here for visual representation -->
                </Grid>
            </Grid>

            <!-- ===== PAGE: SETTINGS ===== -->
            <Grid Visibility="{Binding IsSettingsPage, Converter={StaticResource BoolToVis}}" Style="{StaticResource PageGridStyle}">
                <Grid DataContext="{Binding DataContext.SettingsViewModel, RelativeSource={RelativeSource AncestorType=Window}}" Margin="28,24,28,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,22">
                        <TextBlock Text="Settings" Style="{StaticResource PageHeader}" />
                        <TextBlock Text="Application and cleanup configurations" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0" FontSize="13" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,18">
                        <Button Content="Save Settings" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}" />
                    </StackPanel>
                    
                    <StackPanel Grid.Row="2">
                        <CheckBox Content="Enable System Notifications" IsChecked="{Binding EnableNotifications}" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,12" />
                        <TextBlock Text="Critical Disk Space Threshold (GB):" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding CriticalDiskSpaceThresholdGb}" Width="150" HorizontalAlignment="Left" Margin="0,0,0,12" />
                        
                        <TextBlock Text="Junk File Warning Threshold (MB):" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding JunkFileWarningThresholdMb}" Width="150" HorizontalAlignment="Left" Margin="0,0,0,12" />
                        
                        <TextBlock Text="Large File Threshold (MB):" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding LargeFileThresholdMb}" Width="150" HorizontalAlignment="Left" Margin="0,0,0,12" />
                    </StackPanel>
                </Grid>
            </Grid>
            <!-- ===== LIVE LOG PANEL (Row 1 of outer grid) ===== -->
            <Border Grid.Row="1"
                    Background="{StaticResource BgBase}"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="0,1,0,0"
                    Visibility="{Binding IsLogVisible, Converter={StaticResource BoolToVis}}">
                <Grid Height="160">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Log Header -->
                    <Border Grid.Row="0" Background="{StaticResource BgSurface}" Padding="12,5">
                        <DockPanel>
                            <TextBlock Text="Live Log" DockPanel.Dock="Left"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="11" FontWeight="SemiBold" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Content="Clear"
                                        Style="{StaticResource SecondaryButton}"
                                        Command="{Binding ClearLogCommand}"
                                        Padding="8,3" FontSize="10" Margin="0,0,6,0" />
                                <Button Content="Hide"
                                        Style="{StaticResource SecondaryButton}"
                                        Command="{Binding ToggleLogCommand}"
                                        Padding="8,3" FontSize="10" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Log Entries -->
                    <ListBox x:Name="LogListBox" Grid.Row="1"
                             ItemsSource="{Binding LogStore.Entries}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.CanContentScroll="False"
                             FontFamily="Consolas"
                             FontSize="11">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="12,2" />
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="IsHitTestVisible" Value="False" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <TextBlock Text="{Binding}"
                                                       Foreground="{TemplateBinding Foreground}"
                                                       Padding="{TemplateBinding Padding}"
                                                       FontFamily="Consolas"
                                                       FontSize="11" />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            </Grid>

        </DockPanel>
    </Border>
</Window>
